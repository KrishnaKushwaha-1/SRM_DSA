// 5- Undo and Redo Operations Using Stack

import java.util.Stack;

public class UndoRedo {
    public static void main(String[] args) {

        Stack<Integer> undo = new Stack<>();
        Stack<Integer> redo = new Stack<>();

        undo.push(10);
        undo.push(20);
        undo.push(30);

        System.out.println("Undo Stack: " + undo);

        // Undo Operation
        redo.push(undo.pop());

        System.out.println("After Undo: " + undo);

        // Redo Operation
        undo.push(redo.pop());

        System.out.println("After Redo: " + undo);
    }
}





